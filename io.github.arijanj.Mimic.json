{
    "id": "io.github.arijanj.Mimic",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "mimic",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland",
        "--filesystem=host:ro",
        "--filesystem=/run/current-system/sw/share/applications:ro",
        "--filesystem=/var/lib/flatpak:ro",
        "--filesystem=xdg-data/flatpak:ro",
        "--filesystem=/var/lib/snapd:ro",
        "--filesystem=xdg-config:create"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "mimic",
            "builddir": true,
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/ArijanJ/mimic",
                    "tag": "v1.0.1"
                }
            ]
        }
    ]
}
